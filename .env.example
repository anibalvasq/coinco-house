# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=<random-hex-32>

# Household UUID (from Supabase after running seed migration)
HOUSEHOLD_ID=<uuid>

# CORS — comma-separated. For bundled iOS add: capacitor://localhost,ionic://localhost
CORS_ORIGINS=https://your-project.vercel.app,http://localhost:5173

# Session cookies — bundled Capacitor iOS (cross-origin API to Vercel):
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# Email reports (Resend)
RESEND_API_KEY=re_<your-api-key>
FROM_EMAIL=CoinCo House <notifications@yourdomain.com>

# Vercel Cron Jobs
CRON_SECRET=<random-hex-32>
