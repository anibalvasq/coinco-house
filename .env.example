# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=<random-hex-32>

# Household UUID (from Supabase after running seed migration)
HOUSEHOLD_ID=<uuid>

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://your-project.vercel.app,http://localhost:5173

# Email reports (Resend — https://resend.com)
RESEND_API_KEY=re_<your-api-key>
# Must be a verified sender domain in Resend. Use onboarding@resend.dev for testing.
FROM_EMAIL=CoinCo House <notifications@yourdomain.com>

# Vercel Cron Job secret — generate: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in Vercel Dashboard → Settings → Environment Variables → CRON_SECRET
CRON_SECRET=<random-hex-32>
