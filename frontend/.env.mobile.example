# Copy to .env.production.local before `npm run build:mobile`
# Your deployed Vercel URL (no trailing slash)
VITE_API_BASE_URL=https://your-project.vercel.app/api/v1

# Optional: load the live site in the WebView instead of bundling dist.
# If set, run `CAPACITOR_SERVER_URL=... npx cap sync ios` (overrides bundled mode).
# CAPACITOR_SERVER_URL=https://your-project.vercel.app
